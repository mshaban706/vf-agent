# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── API Server ─────────────────────────────────────────────
API_PORT=4000
API_HOST=localhost
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGIN=http://localhost:5173

# ─── Redis (Phase 2+) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AI Providers ───────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
DEEPSEEK_API_KEY=

# ─── Default AI Model ───────────────────────────────────────
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4o

# ─── API Key Encryption (REQUIRED to save provider keys) ────
# Any long random string. Used for AES-256-GCM encryption of
# provider API keys stored in the database. Server-side only.
API_KEY_ENCRYPTION_SECRET=change-me-to-another-long-random-string

# ─── Desktop App ────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Sandbox Mode ───────────────────────────────────────────
SANDBOX_MODE=true
